# ─── Supabase (obligatorio) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# ─── TTLock — Smart Locks (obligatorio para cerraduras) ──────────────────────
# Obtener en: https://open.ttlock.com/manager
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_API_URL=https://euapi.ttlock.com
# Token compartido para autenticar webhooks entrantes de TTLock
TTLOCK_WEBHOOK_TOKEN=

# ─── Tuya — Dispositivos IoT (obligatorio para dispositivos inteligentes) ────
# Obtener en: https://platform.tuya.com/
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_REGION=eu
TUYA_UID=

# ─── Vercel Cron (obligatorio en produccion) ─────────────────────────────────
# Se usa para autenticar el cron job /api/ttlock/refresh-all
# Generar con: openssl rand -hex 32
CRON_SECRET=

# ─── Aplicacion ──────────────────────────────────────────────────────────────
# URL publica de la app (fallback: window.location.origin)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Email del superadmin / owner del SaaS (NEXT_PUBLIC_ porque se usa en client y server)
NEXT_PUBLIC_MASTER_EMAIL=tu-email@ejemplo.com
